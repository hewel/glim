{
  "compilerOptions": {
    "allowJs": false,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "plugins": [{ "name": "ts-gleam" }],
    "paths": {
      "vite-gleam": ["./src/types/vite-gleam-shim.d.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "e2e/**/*.ts",
    "vite.config.ts",
    "playwright.config.ts"
  ]
}
