    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "ts-gleam": "^1.1.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-gleam": "^1.7.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
